# ─── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=inventoryos
POSTGRES_PASSWORD=inventoryos_secret
POSTGRES_DB=inventoryos
DATABASE_URL=postgresql+asyncpg://inventoryos:inventoryos_secret@localhost:5432/inventoryos

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=redis_secret
REDIS_URL=redis://:redis_secret@localhost:6379/0

# ─── Auth ──────────────────────────────────────────────────────────────────────
SECRET_KEY=supersecret-change-in-production-must-be-at-least-32-characters-long
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ─── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
